# ═══════════════════════════════════════════════════════════
# SILVIA — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# Anthropic API (required)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Twilio WhatsApp (required for WhatsApp, optional for /test endpoint)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Flask config
PORT=5000
FLASK_DEBUG=true

# Obsidian vault path (where SILVIA writes linked notes)
SILVIA_VAULT_PATH=./silvia_vault

# Security: validate Twilio request signatures
# Set to 'true' in production
VALIDATE_TWILIO=false
